{
  "version": "2026-05-31",
  "policy": {
    "owner": "compliance",
    "scope": "all-in-one-modules",
    "default_retention": "minimo necessario por contrato, lei ou defesa de direito",
    "forbidden_repository_data": [
      "segredos reais",
      "documentos brutos",
      "biometria bruta",
      "prontuario bruto",
      "dados de cartao",
      "chaves privadas"
    ],
    "subject_rights": [
      "acesso",
      "correcao",
      "portabilidade",
      "anonimizacao",
      "revogacao de consentimento",
      "exclusao quando legalmente permitida"
    ]
