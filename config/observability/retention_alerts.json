{
  "version": "2026-05-31",
  "owner": "compliance",
  "scope": "retention-worker",
  "metric_source": "kubernetes-prometheus",
  "runbook": "docs/OPERATIONS.md#retencao-lgpd",
  "labels": {
    "service": "retention-worker",
    "domain": "compliance",
    "data_classification": "sensitive"
  },
  "alerts": {
    "RetentionCronJobFailed": {
      "severity": "critical",
      "description": "CronJob de retencao LGPD falhou no ultimo ciclo.",
      "expr": "increase(kube_job_status_failed{job_name=~\"retention-worker.*\"}[2h]) > 0",
      "for": "10m",
      "response_sla_minutes": 30,
      "evidence": ["failed_job_name", "pod_logs", "retention_policy_version", "incident_ticket"]
    },
    "RetentionCronJobDelayed": {
      "severity": "high",
      "description": "CronJob de retencao LGPD nao conclui ha mais de duas janelas de execucao.",
      "expr": "time() - max(kube_job_status_completion_time{job_name=~\"retention-worker.*\"}) > 7200",
      "for": "15m",
      "response_sla_minutes": 60,
      "evidence": ["last_completion_timestamp", "cronjob_status", "scheduler_events", "incident_ticket"]
    },
    "RetentionBacklogHigh": {
      "severity": "high",
      "description": "Backlog de candidatos de retencao pendentes acima do limite operacional.",
      "expr": "all_in_one_retention_candidates_pending > 500",
      "for": "30m",
      "response_sla_minutes": 120,
      "evidence": ["pending_count", "oldest_candidate_age_seconds", "policy_version", "incident_ticket"]
    },
    "RetentionOldestCandidateTooOld": {
      "severity": "critical",
      "description": "Candidato de retencao LGPD mais antigo excedeu 24 horas.",
      "expr": "all_in_one_retention_oldest_candidate_age_seconds > 86400",
      "for": "15m",
      "response_sla_minutes": 30,
      "evidence": ["oldest_candidate_age_seconds", "candidate_selector_hash", "legal_hold_summary", "incident_ticket"]
    },
    "RetentionDecisionMissing": {
      "severity": "medium",
      "description": "Nao ha novas decisoes de retencao apesar de candidatos pendentes.",
      "expr": "all_in_one_retention_candidates_pending > 0 and increase(all_in_one_retention_decisions_total[2h]) == 0",
      "for": "30m",
      "response_sla_minutes": 240,
      "evidence": ["pending_count", "decision_count_delta", "worker_logs", "incident_ticket"]
    }
  },
  "notification_policy": {
    "critical": ["compliance_oncall", "platform_oncall"],
    "high": ["compliance_oncall"],
    "medium": ["platform_oncall"],
    "include_sensitive_payload": false
  }
}
