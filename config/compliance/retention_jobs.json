{
  "version": "2026-05-31",
  "owner": "compliance",
  "scope": "all-in-one-modules",
  "audit_events": [
    "compliance.retention.reviewed",
    "compliance.data.anonymized",
    "compliance.data.deleted",
    "compliance.legal_hold.applied"
  ],
  "jobs": {
    "retention_review_daily": {
      "schedule": "daily",
      "purpose": "identificar dados vencidos por politica, contrato ou consentimento",
      "required_evidence": ["job_run_id", "module", "policy_version", "candidate_count", "audit_event_id"],
      "dry_run_required": true
    },
    "anonymization_worker_hourly": {
      "schedule": "hourly",
      "purpose": "anonimizar dados permitidos apos avaliacao de base legal",
      "required_evidence": ["job_run_id", "module", "record_selector_hash", "anonymization_method", "audit_event_id"],
      "dry_run_required": false
    },
    "deletion_worker_daily": {
      "schedule": "daily",
      "purpose": "descartar dados excluiveis sem obrigacao legal ou disputa ativa",
      "required_evidence": ["job_run_id", "module", "record_selector_hash", "deletion_receipt_hash", "audit_event_id"],
      "dry_run_required": false
    },
    "legal_hold_reconciliation_daily": {
      "schedule": "daily",
      "purpose": "impedir descarte de registros sob obrigacao legal, fiscal, trabalhista, regulatoria ou defesa de direito",
      "required_evidence": ["job_run_id", "module", "hold_reason", "hold_until", "audit_event_id"],
      "dry_run_required": false
    }
  },
  "module_rules": {
    "identity": {"default_action": "anonymize_non_legal_fields", "legal_hold": ["kyc", "consent", "fraud_prevention"], "minimum_job": "anonymization_worker_hourly", "evidence_domain": "identity_privacy"},
    "business": {"default_action": "minimize_documents_after_approval", "legal_hold": ["kyb", "contract", "tax"], "minimum_job": "retention_review_daily", "evidence_domain": "business_privacy"},
    "permissions": {"default_action": "retain_audit_minimize_actor_metadata", "legal_hold": ["security_audit"], "minimum_job": "retention_review_daily", "evidence_domain": "access_privacy"},
    "finance": {"default_action": "retain_ledger_minimize_auxiliary_data", "legal_hold": ["ledger", "tax", "fraud_prevention"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "finance_privacy"},
    "marketplace": {"default_action": "anonymize_reviews_and_inactive_profiles", "legal_hold": ["orders", "disputes"], "minimum_job": "anonymization_worker_hourly", "evidence_domain": "commerce_privacy"},
    "stock": {"default_action": "minimize_supplier_contacts", "legal_hold": ["supplier_contract", "tax"], "minimum_job": "retention_review_daily", "evidence_domain": "stock_privacy"},
    "delivery": {"default_action": "aggregate_old_location_history", "legal_hold": ["proof_of_delivery", "dispute"], "minimum_job": "anonymization_worker_hourly", "evidence_domain": "delivery_privacy"},
    "riders": {"default_action": "minimize_documents_after_contract_end", "legal_hold": ["rider_contract", "fraud_prevention"], "minimum_job": "retention_review_daily", "evidence_domain": "rider_privacy"},
    "services": {"default_action": "mask_addresses_after_contract_end", "legal_hold": ["service_contract", "visit_evidence", "dispute"], "minimum_job": "anonymization_worker_hourly", "evidence_domain": "services_privacy"},
    "mobility": {"default_action": "aggregate_old_routes", "legal_hold": ["payment_receipt", "safety_dispute"], "minimum_job": "anonymization_worker_hourly", "evidence_domain": "mobility_privacy"},
    "jobs": {"default_action": "delete_or_anonymize_inactive_private_resumes", "legal_hold": ["ctps_document", "application_audit", "labor_dispute"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "jobs_privacy"},
    "erp": {"default_action": "minimize_personal_fields_keep_fiscal_records", "legal_hold": ["tax", "accounting"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "erp_privacy"},
    "wms": {"default_action": "minimize_operator_metadata", "legal_hold": ["inventory_audit", "tax"], "minimum_job": "retention_review_daily", "evidence_domain": "wms_privacy"},
    "tms": {"default_action": "minimize_tracking_after_delivery_window", "legal_hold": ["freight_document", "proof_of_delivery", "tax"], "minimum_job": "retention_review_daily", "evidence_domain": "tms_privacy"},
    "crm": {"default_action": "delete_or_anonymize_opted_out_leads", "legal_hold": ["lead_origin_proof"], "minimum_job": "deletion_worker_daily", "evidence_domain": "crm_privacy"},
    "bpm": {"default_action": "minimize_completed_process_payloads", "legal_hold": ["approval_audit"], "minimum_job": "retention_review_daily", "evidence_domain": "bpm_privacy"},
    "document": {"default_action": "apply_document_class_retention_and_secure_disposal", "legal_hold": ["document_classification", "signature", "contract", "legal_case"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "document_privacy"},
    "hr": {"default_action": "retain_labor_records_minimize_dependents", "legal_hold": ["labor", "payroll", "occupational_health"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "hr_privacy"},
    "health": {"default_action": "retain_medical_records_by_regulation_minimize_auxiliary_data", "legal_hold": ["medical_record", "prescription", "clinical_consent"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "health_privacy"},
    "vision": {"default_action": "delete_raw_recordings_after_short_ttl", "legal_hold": ["security_incident", "investigation"], "minimum_job": "deletion_worker_daily", "evidence_domain": "vision_privacy"},
    "legal": {"default_action": "retain_cases_by_mandate_and_legal_deadline", "legal_hold": ["legal_case", "mandate", "contract"], "minimum_job": "legal_hold_reconciliation_daily", "evidence_domain": "legal_privacy"},
    "property": {"default_action": "mask_addresses_after_contract_end", "legal_hold": ["lease_contract", "assembly", "maintenance_dispute"], "minimum_job": "retention_review_daily", "evidence_domain": "property_privacy"},
    "bi": {"default_action": "expire_exports_and_keep_aggregated_datasets", "legal_hold": ["export_audit"], "minimum_job": "deletion_worker_daily", "evidence_domain": "bi_privacy"},
    "ai_core": {"default_action": "delete_consent_revoked_memory_and_minimize_prompts", "legal_hold": ["model_audit", "safety_incident"], "minimum_job": "deletion_worker_daily", "evidence_domain": "ai_privacy"},
    "api_hub": {"default_action": "redact_payload_logs_and_rotate_deleted_clients", "legal_hold": ["security_audit", "webhook_dispute"], "minimum_job": "anonymization_worker_hourly", "evidence_domain": "api_privacy"}
  },
  "safety_rules": {
    "requires_subject_rights_link": true,
    "requires_dry_run_before_first_production_deletion": true,
    "requires_immutable_audit": true,
    "forbidden_without_legal_review": [
      "delete_ledger",
      "delete_tax_record",
      "delete_medical_record",
      "delete_labor_record",
      "delete_signed_contract"
    ]
  }
}
